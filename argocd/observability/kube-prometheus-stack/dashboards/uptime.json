{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["homelab", "uptime", "uptime-kuma"],
  "title": "Uptime — Serviços (Uptime Kuma)",
  "uid": "uptime-kuma",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "monitor", "label": "Monitor", "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(monitor_status, monitor_name)",
        "refresh": 2, "sort": 1, "includeAll": true, "allValue": ".+", "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Monitores UP",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [ { "refId": "A", "expr": "count(monitor_status{monitor_name=~\"$monitor\"} == 1) or vector(0)" } ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2, "type": "stat", "title": "Monitores DOWN",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [ { "refId": "A", "expr": "count(monitor_status{monitor_name=~\"$monitor\"} == 0) or vector(0)" } ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3, "type": "stat", "title": "Response time médio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [ { "refId": "A", "expr": "avg(monitor_response_time{monitor_name=~\"$monitor\"})" } ],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 1000 } ] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4, "type": "stat", "title": "Disponibilidade (janela)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [ { "refId": "A", "expr": "100 * avg(avg_over_time((monitor_status{monitor_name=~\"$monitor\"} == bool 1)[$__range:1m]))" } ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99.5 } ] } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5, "type": "state-timeline", "title": "Status por monitor (linha do tempo)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "targets": [ { "refId": "A", "expr": "monitor_status{monitor_name=~\"$monitor\"}", "legendFormat": "{{monitor_name}}" } ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "mappings": [ { "type": "value", "options": {
            "0": { "text": "DOWN", "color": "red" },
            "1": { "text": "UP", "color": "green" },
            "2": { "text": "PENDING", "color": "yellow" },
            "3": { "text": "MAINTENANCE", "color": "blue" }
          } } ],
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 }, { "color": "yellow", "value": 2 }, { "color": "blue", "value": 3 } ] }
        },
        "overrides": []
      },
      "options": { "showValue": "never", "mergeValues": true, "rowHeight": 0.9, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Response time por monitor (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "targets": [ { "refId": "A", "expr": "monitor_response_time{monitor_name=~\"$monitor\"}", "legendFormat": "{{monitor_name}}" } ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 25, "gradientMode": "opacity", "lineInterpolation": "smooth", "showPoints": "never", "spanNulls": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Certificado — dias restantes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "targets": [ { "refId": "A", "expr": "monitor_cert_days_remaining{monitor_name=~\"$monitor\"}", "legendFormat": "{{monitor_name}}" } ],
      "fieldConfig": { "defaults": { "unit": "d", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "lineInterpolation": "smooth", "showPoints": "never", "spanNulls": true }, "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 14 }, { "color": "green", "value": 30 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8, "type": "table", "title": "Monitores — status atual",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [ { "refId": "A", "expr": "monitor_status{monitor_name=~\"$monitor\"}", "instant": true, "format": "table" } ],
      "transformations": [ { "id": "organize", "options": {
        "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "namespace": true, "service": true, "endpoint": true, "container": true, "pod": true },
        "renameByName": { "monitor_name": "Monitor", "monitor_type": "Tipo", "monitor_url": "URL", "Value": "Status" }
      } } ],
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byName", "options": "Status" }, "properties": [
        { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" }, "2": { "text": "PENDING", "color": "yellow" }, "3": { "text": "MAINTENANCE", "color": "blue" } } } ] },
        { "id": "custom.cellOptions", "value": { "type": "color-background" } }
      ] } ] },
      "options": { "showHeader": true }
    }
  ]
}
