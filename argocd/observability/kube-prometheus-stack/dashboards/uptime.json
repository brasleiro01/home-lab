{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": [
    "homelab",
    "uptime",
    "uptime-kuma"
  ],
  "title": "Uptime — Serviços (Uptime Kuma)",
  "uid": "uptime-kuma",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "monitor",
        "label": "Monitor",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "mimir"
        },
        "query": "label_values(monitor_status, monitor_name)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {
          "text": "Todos",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "text",
      "transparent": false,
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "![meutudo](data:image/svg+xml;base64,)"
      },
      "id": 108
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Monitores no ar",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(monitor_status{monitor_name=~\"$monitor\"} == 1) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "transparent": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Monitores fora do ar",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(monitor_status{monitor_name=~\"$monitor\"} == 0) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "transparent": false
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tempo de resposta (médio)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(monitor_response_time{monitor_name=~\"$monitor\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "transparent": false
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Disponibilidade (janela)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * avg(avg_over_time((monitor_status{monitor_name=~\"$monitor\"} == bool 1)[$__range:1m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "transparent": false
    },
    {
      "id": 5,
      "type": "state-timeline",
      "title": "Status por monitor (linha do tempo)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "refId": "A",
          "expr": "monitor_status{monitor_name=~\"$monitor\"}",
          "legendFormat": "{{monitor_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 85,
            "lineWidth": 0
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FORA DO AR",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "NO AR",
                  "color": "green",
                  "index": 1
                },
                "2": {
                  "text": "PENDENTE",
                  "color": "yellow",
                  "index": 2
                },
                "3": {
                  "text": "MANUTENÇÃO",
                  "color": "blue",
                  "index": 3
                }
              }
            }
          ],
          "color": {
            "mode": "palette-classic"
          },
          "noValue": "sem dados"
        },
        "overrides": []
      },
      "options": {
        "showValue": "never",
        "mergeValues": true,
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "transparent": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tempo de resposta por monitor (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "monitor_response_time{monitor_name=~\"$monitor\"}",
          "legendFormat": "{{monitor_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "transparent": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Certificado — dias restantes",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "monitor_cert_days_remaining{monitor_name=~\"$monitor\"}",
          "legendFormat": "{{monitor_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 14
              },
              {
                "color": "green",
                "value": 30
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "transparent": false
    },
    {
      "id": 8,
      "type": "table",
      "title": "Monitores — status atual (+ código HTTP)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "refId": "STATUS",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "format": "table",
          "expr": "label_replace(monitor_status, \"url\", \"$1\", \"monitor_url\", \"(.*?)/*$\")"
        },
        {
          "refId": "HTTP",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "format": "table",
          "expr": "label_replace(probe_http_status_code, \"url\", \"$1\", \"instance\", \"(.*?)/*$\")"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "field": "url",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "job 1": true,
              "job 2": true,
              "instance": true,
              "monitor_url": true,
              "namespace 1": true,
              "namespace 2": true,
              "service 1": true,
              "service 2": true,
              "container 1": true,
              "container 2": true,
              "pod 1": true,
              "pod 2": true,
              "endpoint 1": true,
              "endpoint 2": true,
              "prometheus 1": true,
              "prometheus 2": true,
              "env": true,
              "tipo": true,
              "cluster 1": true,
              "cluster 2": true
            },
            "indexByName": {
              "monitor_name": 0,
              "monitor_type": 1,
              "url": 2,
              "Value #STATUS": 3,
              "Value #HTTP": 4
            },
            "renameByName": {
              "monitor_name": "Monitor",
              "monitor_type": "Tipo",
              "url": "URL",
              "Value #STATUS": "Status",
              "Value #HTTP": "HTTP"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "FORA DO AR",
                        "color": "red"
                      },
                      "1": {
                        "text": "NO AR",
                        "color": "green"
                      },
                      "2": {
                        "text": "PENDENTE",
                        "color": "yellow"
                      },
                      "3": {
                        "text": "MANUTENÇÃO",
                        "color": "blue"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "HTTP"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 300
                    },
                    {
                      "color": "red",
                      "value": 400
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transparent": false
    }
  ],
  "refresh": "5s",
  "timepicker": {
