{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": [
    "homelab",
    "sre",
    "slo"
  ],
  "title": "SLOs — Error Budget & Burn Rate",
  "uid": "slo-overview",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "5s",
  "timepicker": {
    "refresh_intervals": [
      "1s",
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ],
    "time_options": [
      "1h",
      "6h",
      "12h",
      "24h",
      "2d",
      "7d",
      "30d"
    ]
  },
  "panels": [
    {
      "type": "text",
      "transparent": false,
      "id": 100,
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "![meutudo](data:image/svg+xml;base64,)"
      }
    },
    {
      "id": 1,
      "type": "table",
      "title": "SLOs — objetivo · budget restante · burn rate",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "transparent": false,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "refId": "OBJ",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "format": "table",
          "expr": "slo:objective:ratio"
        },
        {
          "refId": "BUD",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "format": "table",
          "expr": "slo:period_error_budget_remaining:ratio"
        },
        {
          "refId": "BURN",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "instant": true,
          "format": "table",
          "expr": "slo:period_burn_rate:ratio"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "sloth_id": true,
              "sloth_mode": true,
              "sloth_spec": true,
              "sloth_version": true,
              "sloth_objective": true,
              "tier": true,
              "prometheus": true,
              "namespace": true,
              "container": true,
              "endpoint": true,
              "pod": true,
              "service": true
            },
            "indexByName": {
              "sloth_service": 0,
              "sloth_slo": 1,
              "Value #OBJ": 2,
              "Value #BUD": 3,
              "Value #BURN": 4
            },
            "renameByName": {
              "sloth_service": "Serviço",
              "sloth_slo": "SLO",
              "Value #OBJ": "Objetivo",
              "Value #BUD": "Budget restante",
              "Value #BURN": "Burn rate (período)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Objetivo"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Budget restante"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 0.1
                    },
                    {
                      "color": "green",
                      "value": 0.5
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Burn rate (período)"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 2
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error budget restante (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "transparent": false,
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "100 * slo:period_error_budget_remaining:ratio",
          "legendFormat": "{{sloth_service}}/{{sloth_slo}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Burn rate (atual)",
      "datasource": {
        "type": "prometheus",
        "uid": "mimir"
      },
      "transparent": false,
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 11
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "mimir"
          },
          "expr": "slo:current_burn_rate:ratio",
          "legendFormat": "{{sloth_service}}/{{sloth_slo}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    }
  ]
}