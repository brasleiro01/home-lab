apiVersion: v1
kind: Secret
metadata:
  name: k8s-monitor-secrets
  namespace: k8s-monitor
type: Opaque
stringData:
  # Postgres
  POSTGRES_DB:       k8smonitor
  POSTGRES_USER:     k8smonitor
  POSTGRES_PASSWORD: TROQUE_ESTA_SENHA

  # URL de conexão — deve usar a mesma senha acima
  DATABASE_URL: postgresql://k8smonitor:TROQUE_ESTA_SENHA@postgres-k8s-monitor:5432/k8smonitor

  # Google Gemini (https://aistudio.google.com/apikey)
  gemini-api-key: AIza...

  # Discord Webhook
  discord-webhook-url: https://discord.com/api/webhooks/ID/TOKEN

  # Google OAuth — opcional (deixe vazio para desativar o botão Google no login)
  google-client-id: ""
